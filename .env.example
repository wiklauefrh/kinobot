# Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username
SUPER_ADMIN_IDS=123456789,987654321

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/kinobot_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Userbot (Pyrogram) - Optional
API_ID=123456
API_HASH=abcdef1234567890abcdef1234567890
USERBOT_SESSION_STRING=

# Telegram Channels/Groups
BASE_CHANNEL_ID=-1001234567890
LOG_CHANNEL_ID=-1001234567890
COMMENT_GROUP_ID=-1001234567890

# Broadcast Settings
BROADCAST_BOT_RATE=28
BROADCAST_USERBOT_RATE=20
ALLOW_PAID_BROADCAST=false

# Logging
LOG_LEVEL=INFO
TZ=Asia/Tashkent

# Feature Flags
FORCE_SUBSCRIPTION=true
MAINTENANCE_MODE=false
